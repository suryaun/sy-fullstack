generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockStatus {
  IN_STOCK
  SOLD_OUT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum ShipmentProvider {
  DELHIVERY
}

enum ShipmentStatus {
  PENDING
  BOOKED
  FAILED
  CANCELLED
}

enum BackInStockStatus {
  ACTIVE
  NOTIFIED
  CANCELLED
}

enum PieceStatus {
  AVAILABLE
  SOLD
  RETURNED
  REMOVED
}

model Product {
  id              String      @id @default(cuid())
  sequenceNumber  Int         @default(autoincrement())
  name            String
  description     String
  fabric          String
  craft           String
  lengthInMeters  Float
  blouseIncluded  Boolean     @default(false)
  hasHandloomMark Boolean     @default(false)
  priceInPaise    Int
  stockStatus     StockStatus @default(IN_STOCK)
  imageUrl        String
  imagePublicId   String?
  instagramReelUrl String?
  hidden          Boolean     @default(false)

  // Delivery / shipping defaults
  packageType     String      @default("Plastic cover/Flyer")
  packageLengthCm Int         @default(40)
  packageWidthCm  Int         @default(30)
  packageHeightCm Int         @default(6)
  weightGrams     Int         @default(800)
  sourcePincode   String      @default("560064")

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orderItems      OrderItem[]
  colors          ProductColor[]
  images          ProductImage[]
  notifyRequests  BackInStockRequest[]
  productCategories ProductCategory[]

  @@index([stockStatus])
  @@index([hidden])
}

model Category {
  id                String            @id @default(cuid())
  name              String
  slug              String
  parentId          String?
  sortOrder         Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  parent            Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]        @relation("CategoryHierarchy")
  productCategories ProductCategory[]

  @@index([parentId, sortOrder])
  @@unique([parentId, slug])
}

model ProductAttribute {
  id        String   @id @default(cuid())
  kind      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, name])
  @@index([kind])
}

model ProductCategory {
  productId         String
  categoryId        String
  assignedAt        DateTime          @default(now())

  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductImage {
  id              String      @id @default(cuid())
  productId       String
  imageUrl        String
  imagePublicId   String?
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())

  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductColor {
  id              String               @id @default(cuid())
  productId       String
  name            String
  colorCode       String?
  borderColorName String?
  borderColorCode String?
  sku             String?              @unique
  isDefault       Boolean              @default(false)
  stockQuantity   Int                  @default(0)
  priceInPaise    Int?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  images          ProductColorImage[]
  notifyRequests  BackInStockRequest[]
  orderItems      OrderItem[]
  pieces          ProductPiece[]

  @@unique([productId, name])
  @@index([productId, isDefault])
  @@index([productId, stockQuantity])
}

model ProductColorImage {
  id              String        @id @default(cuid())
  productColorId  String
  imageUrl        String
  imagePublicId   String?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  productColor    ProductColor  @relation(fields: [productColorId], references: [id], onDelete: Cascade)

  @@index([productColorId, sortOrder])
}

model ProductPiece {
  id                   String      @id @default(cuid())
  serial               String      @unique
  productColorId       String
  pieceNumber          Int
  status               PieceStatus @default(AVAILABLE)
  allocatedOrderItemId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  productColor         ProductColor @relation(fields: [productColorId], references: [id], onDelete: Restrict)
  orderItem            OrderItem?   @relation(fields: [allocatedOrderItemId], references: [id], onDelete: SetNull)

  @@unique([productColorId, pieceNumber])
  @@index([status])
  @@index([productColorId, status])
}

model Order {
  id                String      @id @default(cuid())
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?     @unique
  razorpaySignature String?
  status                  OrderStatus @default(PENDING)
  amountInPaise           Int
  currency                String      @default("INR")
  customerName            String
  customerEmail           String
  customerPhone           String
  deliveryState           String?
  deliveryAddressSnapshot Json?
  invoiceNumber           String?     @unique
  invoiceDate             DateTime?
  taxableAmountInPaise    Int         @default(0)
  cgstInPaise             Int         @default(0)
  sgstInPaise             Int         @default(0)
  igstInPaise             Int         @default(0)
  notes                   Json?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  items                   OrderItem[]
  shipments               OrderShipment[]

  @@index([status])
  @@index([invoiceNumber])
}

model OrderShipment {
  id                    String           @id @default(cuid())
  orderId               String
  provider              ShipmentProvider
  status                ShipmentStatus   @default(PENDING)
  sourcePincode         String?
  providerShipmentId    String?
  providerWaybill       String?
  providerReference     String?
  serviceablePostalCode Boolean?
  requestPayload        Json?
  responsePayload       Json?
  failureMessage        String?
  bookedAt              DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  order                  Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@index([provider, status])
  @@index([providerShipmentId])
  @@index([providerWaybill])
}

model OrderItem {
  id                   String  @id @default(cuid())
  orderId              String
  productId            String
  productColorId       String?
  colorNameAtTime      String?
  quantity             Int     @default(1)
  priceAtTime          Int
  hsnCode              String?
  gstRatePercent       Float   @default(0)
  taxableAmountInPaise Int     @default(0)
  cgstInPaise          Int     @default(0)
  sgstInPaise          Int     @default(0)
  igstInPaise          Int     @default(0)

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productColor ProductColor? @relation(fields: [productColorId], references: [id], onDelete: SetNull)
  pieces       ProductPiece[]

  @@index([orderId])
  @@index([productId])
  @@index([productColorId])
}

model AdminUser {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  passwordHash  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CustomerUser {
  id              String      @id @default(cuid())
  mobile          String      @unique
  fullName        String?
  email           String?
  profileComplete Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  otps            MobileOtp[]
  backInStockRequests BackInStockRequest[]
  addresses       CustomerAddress[]

  @@index([mobile])
}

model CustomerAddress {
  id            String       @id @default(cuid())
  customerId    String
  fullName      String
  phoneNumber   String
  line1         String
  line2         String?
  landmark      String?
  city          String
  state         String
  postalCode    String
  country       String       @default("India")
  addressType   String?
  isDefault     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  customer      CustomerUser @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isDefault])
  @@index([customerId, updatedAt])
}

model BackInStockRequest {
  id              String            @id @default(cuid())
  customerId      String
  productId       String
  productColorId  String
  status          BackInStockStatus @default(ACTIVE)
  requestedAt     DateTime          @default(now())
  notifiedAt      DateTime?
  cancelledAt     DateTime?

  customer        CustomerUser      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productColor    ProductColor      @relation(fields: [productColorId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId, productColorId])
  @@index([productColorId, status])
  @@index([productId, status])
}

model MobileOtp {
  id          String        @id @default(cuid())
  mobile      String
  codeHash    String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())
  customerId  String?

  customer    CustomerUser? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([mobile, createdAt])
  @@index([expiresAt])
}

model InvoiceSequence {
  financialYear String @id
  lastSequence  Int    @default(0)
}

// Holds a short-lived stock claim while the user is in the Razorpay payment
// modal. TTL is 10 minutes. The same customer can refresh their own reservation.
// A different customer is blocked until the reservation expires or is released.
model StockReservation {
  id             String   @id @default(cuid())
  productColorId String
  customerId     String   // CustomerUser.id  (or a guest token for unauthenticated)
  razorpayOrderId String? // set when the Razorpay order is created
  quantity       Int
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productColorId, expiresAt])
  @@index([customerId])
  @@index([razorpayOrderId])
}
