# Shared
DATABASE_URL=postgresql://postgres:postgres@db:5432/seere_yaana_db?schema=public
JWT_SECRET=replace-with-a-long-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

# Storage (ImageKit)
IMAGEKIT_PUBLIC_KEY=replace-with-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=replace-with-imagekit-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_FOLDER=/seere-yaana/products
IMAGE_UPLOAD_WEBP_QUALITY=82
IMAGE_UPLOAD_MAX_BYTES=15728640

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://api:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
NEXT_PUBLIC_BRAND_LOGO=https://res.cloudinary.com/demo/image/upload/v1/sample.jpg

# Auth (NextAuth / Auth.js)
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=http://localhost:3445
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
FACEBOOK_CLIENT_ID=replace-with-facebook-app-id
FACEBOOK_CLIENT_SECRET=replace-with-facebook-app-secret
AUTH_APPLE_ID=replace-with-apple-services-id
AUTH_APPLE_SECRET=replace-with-apple-client-secret

# Mobile OTP
MOBILE_OTP_EXPIRY_MINUTES=5
MOBILE_OTP_BYPASS=true

# Admin Access (comma-separated mobile numbers)
ADMIN_MOBILE_NUMBERS=9999999999
